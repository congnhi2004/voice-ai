# Runtime
ENVIRONMENT=local
PORT=8080
LOG_LEVEL=INFO
SERVICE_NAME=voice-ai
SERVICE_VERSION=0.1.0
APP_MODULE=app.main:app
WORKER_COMMAND=python -m app.worker

# API behavior
TTS_PROVIDER=local
MAX_INPUT_CHARS=5000
MAX_UPLOAD_BYTES=524288000
REQUEST_TIMEOUT_SECONDS=3600
JOB_DISPATCH_MODE=inline
WORKER_CONCURRENCY=1
API_KEYS=CHANGE_ME_LOCAL_ONLY
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8080

# Auth and billing
# Local development can run without AUTH_JWT_SECRET; production/staging/public must set it.
AUTH_STORAGE_PATH=/app/data/auth-billing.sqlite3
AUTH_JWT_SECRET=
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=60
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=https://example.com/billing/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://example.com/billing/cancel
STRIPE_PORTAL_RETURN_URL=https://example.com/account/billing
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# OpenAI Text-to-Speech
OPENAI_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral
OPENAI_TTS_RESPONSE_FORMAT=wav

# Local public runtime guard
# Keep real deployment values in an untracked .env.runtime or .env.local file.
# Example production runtime file:
# PUBLIC_DEMO_PROFILE=production
# REQUIRE_REAL_TTS=1
# TTS_PROVIDER=openai
# OPENAI_API_KEY=CHANGE_ME_OPENAI_KEY
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=marin
# OPENAI_TTS_RESPONSE_FORMAT=wav
PUBLIC_DEMO_PROFILE=
REQUIRE_REAL_TTS=0
RUNTIME_ENV_FILE=

# Google Cloud Text-to-Speech
GCP_PROJECT_ID=voice-ai-dev
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_REGION=us-central1

# Artifact storage
# Local keeps public demo URLs on this FastAPI instance. Set STORAGE_PROVIDER=gcs
# in staging/production to upload generated audio/video artifacts to private GCS
# buckets and return time-limited signed URLs.
STORAGE_PROVIDER=local
AUDIO_STORAGE_MODE=local
AUDIO_STORAGE_DIR=/app/data/audio
AUDIO_BASE_URL=http://localhost:8080/audio
GCS_AUDIO_BUCKET=
GCS_AUDIO_PREFIX=voice-ai/audio
SIGNED_URL_TTL_SECONDS=3600

# Video localization storage and jobs
VIDEO_LOCALIZATION_ENABLED=true
LOCALIZATION_PROVIDER=auto
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_TRANSLATION_MODEL=gpt-4o-mini
VIDEO_STORAGE_MODE=local
VIDEO_STORAGE_DIR=/app/data/video
ARTIFACT_STORAGE_DIR=/app/data/artifacts
GCS_ARTIFACT_BUCKET=
GCS_SOURCE_VIDEO_PREFIX=voice-ai/video/source
GCS_RENDERED_VIDEO_PREFIX=voice-ai/video/rendered
GCS_INTERMEDIATE_PREFIX=voice-ai/video/intermediate
CLOUD_TASKS_QUEUE=voice-ai-video
CLOUD_TASKS_LOCATION=us-central1
CLOUD_TASKS_HANDLER_PATH=/internal/tasks/video-localization
CLOUD_TASKS_SERVICE_ACCOUNT=
VIDEO_STAGE_TIMEOUT_SECONDS=3300
FFMPEG_THREADS=2
MAX_VIDEO_DURATION_SECONDS=1800

# Observability and MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=voice-ai-tts-synthesis
MLFLOW_VIDEO_EXPERIMENT_NAME=voice-ai-video-localization
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts
MLFLOW_BACKEND_STORE_URI=sqlite:////mlflow/mlflow.db
ENABLE_MLFLOW=true
STRUCTURED_LOGS=true
LOG_VIDEO_STAGE_EVENTS=true
VIDEO_OBSERVABILITY_STAGES=upload,stt,translation,tts,alignment,render,delivery

# Local compose paths
LOCAL_AUDIO_DIR=./data/audio
LOCAL_VIDEO_DIR=./data/video
LOCAL_ARTIFACT_DIR=./data/artifacts
LOCAL_MLFLOW_DIR=./mlruns
LOCAL_MLFLOW_ARTIFACT_DIR=./artifacts/mlflow
